DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Supabase PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres

# Redis URL for Django Channels layer
# Local: redis://127.0.0.1:6379/0
# Upstash / Remote: redis://:password@host:port/0
REDIS_URL=redis://127.0.0.1:6379/0

# JWT Secret key (can be the same as Django SECRET_KEY or a separate one)
JWT_SECRET_KEY=your-jwt-secret-key-here

# Firebase Admin SDK (Django)
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Firebase Client SDK (React - use VITE_ prefix)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
